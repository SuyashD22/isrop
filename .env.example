# ════════════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT — copy this file to .env and fill in real values
# ════════════════════════════════════════════════════════════════════════════════

# ─── Frontend (Next.js / Vercel) ─────────────────────────────────────────────
# In production, set NEXT_PUBLIC_API_URL in the Vercel dashboard under
# Settings → Environment Variables (applies to all branches or per-branch).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Backend (FastAPI / Render) ──────────────────────────────────────────────
# In production, set these in the Render dashboard under Environment → Secret Files
# or directly as environment variables.

# The public Vercel URL of the frontend — used for CORS allow-list
FRONTEND_URL=http://localhost:3000

# Comma-separated extra origins to allow (JSON list format)
# CORS_ORIGINS=["https://your-app.vercel.app"]

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000   # Render overrides this automatically via $PORT

# ─── Inference ───────────────────────────────────────────────────────────────
MAX_TILE_SIZE_MB=50
N_REFERENCE_FRAMES=3
DEVICE=cpu          # Use 'cuda' if GPU is available

# ─── Model Paths (local Docker / Render persistent disk) ─────────────────────
MODELS_DIR=./models
MODEL_CHECKPOINT_PATH=./models/inpainting/best_model.pt
CLOUD_SEG_CHECKPOINT_PATH=./models/cloud_seg/best_model.pt

# ─── Data Sources (Copernicus / Sentinel) ────────────────────────────────────
SENTINEL_USER=your_copernicus_username
SENTINEL_PASS=your_copernicus_password

# ─── Google Drive (Colab checkpoint persistence) ─────────────────────────────
GDRIVE_CHECKPOINT_DIR=/content/drive/MyDrive/lissclear/checkpoints
