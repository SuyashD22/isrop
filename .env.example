# ─── Model Paths ────────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=./data/checkpoints/inpainting/best_model.pt
CLOUD_SEG_CHECKPOINT_PATH=./data/checkpoints/cloud_seg/best_model.pt

# ─── Server ──────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── Inference ───────────────────────────────────────────────────────────────────
MAX_TILE_SIZE_MB=50
N_REFERENCE_FRAMES=3
BATCH_SIZE=4
DEVICE=cuda          # Use 'cpu' if no GPU available

# ─── Data Sources (set in Colab secrets or local .env) ───────────────────────────
SENTINEL_USER=your_copernicus_username
SENTINEL_PASS=your_copernicus_password

# ─── Hugging Face (for model hosting) ────────────────────────────────────────────
HF_TOKEN=your_huggingface_token
HF_REPO_ID=your-username/lissclear

# ─── Google Drive (Colab checkpoint persistence) ─────────────────────────────────
GDRIVE_CHECKPOINT_DIR=/content/drive/MyDrive/lissclear/checkpoints
